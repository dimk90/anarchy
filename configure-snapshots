#!/bin/bash

# Treat unset variables as an error and exit immediately
set -o nounset


## Imports


set -o errexit # exit on non-zero exit code

COMMON=$(curl -fsSL "https://dimk90.github.io/anarchy/common")
# shellcheck source=common
source <(echo "$COMMON")

set +o errexit # disable exit on non-zero exit code


## Constants


# UKI built by configure-boot — its BLAKE2B is embedded in limine.conf and its
# NVRAM entry must stay ahead of Limine in the boot order.
UKI_PATH='/boot/EFI/Linux/arch-linux.efi'
UKI_LABEL='Arch Linux (UKI)'

# Limine bootloader binary + NVRAM entry
LIMINE_LABEL='Limine (Snapshots)'
LIMINE_EFI_SRC='/usr/share/limine/BOOTX64.EFI'
LIMINE_EFI_DST='/boot/EFI/limine/limine_x64.efi'
LIMINE_LOADER='\EFI\limine\limine_x64.efi'

# Canonical Limine config (the deep copy under EFI/limine/ goes stale silently
# and must be removed — limine-snapper-sync only updates the root one).
LIMINE_CONF='/boot/limine.conf'
DEEP_LIMINE_CONF='/boot/EFI/limine/limine.conf'

# post.d hooks limine-snapper-sync runs after rewriting limine.conf (resume
# strip, optional menu flatten). Created here — limine-entry-tool, which ships
# the dir, isn't installed until the Secure Boot step.
BOOT_HOOKS_DIR='/etc/boot/hooks/post.d'

# Encrypted btrfs holding @ and the snapshot holders — must match configure-disk.
CRYPT_NAME='cryptroot'
CRYPT_DEV="/dev/mapper/${CRYPT_NAME}"

# Asset URLs (served by the GitHub Pages site)
BASE_URL='https://dimk90.github.io/anarchy'
LIMINE_CONF_URL="${BASE_URL}/boot/limine.conf"
LIMINE_THEME_URL="${BASE_URL}/boot/limine-theme.conf"
LIMINE_HOOK_URL="${BASE_URL}/boot/99-limine.hook"
LIMINE_DEFAULT_URL="${BASE_URL}/boot/limine.default"
LIMINE_STRIP_HOOK_URL="${BASE_URL}/boot/81-limine-strip-resume"
LIMINE_FLATTEN_HOOK_URL="${BASE_URL}/boot/80-limine-flatten-snapshots"

# Limine menu bitmap fonts (deployed to the ESP root; theme term_font picks one)
LIMINE_FONT_BASE_URL="${BASE_URL}/font/limine"   # /<name>-8x16.bin

# AUR companions: snapshot→Limine entry sync and kernel-update hook
AUR_TOOLS='limine-snapper-sync limine-mkinitcpio-hook'


## Globals (set at runtime)


# Optional components (toggled in select_optional_components)
WANT_HOME=true
WANT_THEME=true
WANT_FLATTEN=true

# Limine menu font (set in select_optional_components when WANT_THEME)
LIMINE_FONT='spleen'

# ESP disk + partition index for the efibootmgr entry (set in verify_prerequisites)
ESP_DISK=''
ESP_IDX=''

# Cryptroot UUID for the holder fstab lines (set in verify_prerequisites)
CRYPT_UUID=''


## Routines


detect_esp_mount() {
    #
    # Print the partition device path mounted at /boot.
    #
    findmnt -n -o SOURCE /boot 2>>"$LOG_FILE"
}


parse_disk_part() {
    #
    # Convert a partition device path to "<disk>|<index>".
    #   /dev/nvme0n1p1 -> /dev/nvme0n1|1
    #   /dev/sda1      -> /dev/sda|1
    # NVMe-style needs the 'p' separator (digit before 'p' before idx).
    #
    local part="$1"
    local disk='' idx=''

    if [[ "$part" =~ ^(.*[0-9])p([0-9]+)$ ]]; then
        disk="${BASH_REMATCH[1]}"
        idx="${BASH_REMATCH[2]}"
    elif [[ "$part" =~ ^(.*[^0-9])([0-9]+)$ ]]; then
        disk="${BASH_REMATCH[1]}"
        idx="${BASH_REMATCH[2]}"
    fi

    echo "${disk}|${idx}"
}


# shellcheck disable=SC2329
is_root_btrfs_subvol_at() {
    #
    # Check whether '/' is mounted on btrfs with subvol=@. The snapshot layout
    # (and the cmdline baked into the UKI) assumes this.
    #
    local fstype subvol
    fstype=$(findmnt -n -o FSTYPE / 2>>"$LOG_FILE")
    [ "$fstype" = 'btrfs' ] || return 1

    subvol=$(findmnt -n -o OPTIONS / 2>>"$LOG_FILE" | grep -oE 'subvol=[^,]+' | head -n 1)
    [ "$subvol" = 'subvol=/@' ] || [ "$subvol" = 'subvol=@' ]
}


# shellcheck disable=SC2329
reorder_bootorder() {
    #
    # Put the UKI first and Limine second in the UEFI boot order, preserving the
    # rest. Returns 1 if either entry can't be found in NVRAM.
    #
    local out uki lim order rest neworder
    out=$(as_root efibootmgr 2>>"$LOG_FILE")

    uki=$(grep -F "$UKI_LABEL" <<< "$out" \
          | grep -oE '^Boot[0-9A-Fa-f]{4}' | head -n1 | sed 's/^Boot//')
    lim=$(grep -F "$LIMINE_LABEL" <<< "$out" \
          | grep -oE '^Boot[0-9A-Fa-f]{4}' | head -n1 | sed 's/^Boot//')

    [ -z "$uki" ] && return 1
    [ -z "$lim" ] && return 1

    order=$(grep -E '^BootOrder:' <<< "$out" | sed -E 's/^BootOrder:[[:space:]]*//')
    rest=$(tr ',' '\n' <<< "$order" | grep -viE "^(${uki}|${lim})$" | paste -sd ',' -)

    if [ -n "$rest" ]; then
        neworder="${uki},${lim},${rest}"
    else
        neworder="${uki},${lim}"
    fi

    as_root efibootmgr --bootorder "$neworder" &>> "$LOG_FILE"
}


# shellcheck disable=SC2329
apply_root_retention() {
    #
    # Retention for the 'root' config: snap-pac is the only trigger, no
    # timeline, a real rollback window, drop empty pre/post pairs.
    #
    as_root snapper -c root set-config \
        ALLOW_GROUPS=wheel             \
        SYNC_ACL=yes                   \
        NUMBER_CLEANUP=yes             \
        NUMBER_MIN_AGE=1800            \
        NUMBER_LIMIT=20                \
        NUMBER_LIMIT_IMPORTANT=10      \
        TIMELINE_CREATE=no             \
        TIMELINE_CLEANUP=yes           \
        TIMELINE_LIMIT_HOURLY=0        \
        TIMELINE_LIMIT_DAILY=0         \
        TIMELINE_LIMIT_WEEKLY=0        \
        TIMELINE_LIMIT_MONTHLY=0       \
        TIMELINE_LIMIT_YEARLY=0        \
        EMPTY_PRE_POST_CLEANUP=yes     \
        EMPTY_PRE_POST_MIN_AGE=1800
}


# shellcheck disable=SC2329
apply_home_retention() {
    #
    # Retention for the 'home' config: timeline is the only trigger, daily
    # granularity with weekly + monthly fallback, pacman irrelevant.
    #
    as_root snapper -c home set-config \
        ALLOW_GROUPS=wheel             \
        SYNC_ACL=yes                   \
        PACMAN_PRE_POST=no             \
        NUMBER_CLEANUP=no              \
        TIMELINE_CREATE=yes            \
        TIMELINE_CLEANUP=yes           \
        TIMELINE_MIN_AGE=1800          \
        TIMELINE_LIMIT_HOURLY=0        \
        TIMELINE_LIMIT_DAILY=7         \
        TIMELINE_LIMIT_WEEKLY=4        \
        TIMELINE_LIMIT_MONTHLY=3       \
        TIMELINE_LIMIT_YEARLY=0        \
        EMPTY_PRE_POST_CLEANUP=no
}


select_optional_components() {
    #
    # Ask which optional components to set up. The core (Limine + root
    # snapshots) is always configured. Sets WANT_HOME / WANT_THEME /
    # WANT_FLATTEN, and LIMINE_FONT when the theme is selected.
    # Returns 1 on cancel.
    #
    local section
    section=$(prefix_printf "$(bullet_section)" 'Select Optional Components')

    local choices
    if choices=$(gum choose --no-limit --selected='*' --cursor='   > '   \
                     --header "${section}"                               \
                     'Home snapshots - timeline config for /home'        \
                     'Limine theme - monochrome HiDPI menu styling'      \
                     'Flatten snapshot submenus - drop the redundant //// menu level'); then
        choices=${choices,,} # convert to lowercase for easier matching
    else
        return 1
    fi

    printf "%s\n" "$section" # repaint header gum cleared on selection

    WANT_HOME=false
    WANT_THEME=false
    WANT_FLATTEN=false
    grep -q 'home snapshots'   <<< "$choices" && WANT_HOME=true
    grep -q 'limine theme'     <<< "$choices" && WANT_THEME=true
    grep -q 'flatten snapshot' <<< "$choices" && WANT_FLATTEN=true

    local num_choice
    num_choice=$([ -n "$choices" ] && wc -l <<< "$choices" || echo 0)
    printf_action "Selected items: ${STYLE_CLR}${num_choice}\n"

    # The menu font lives in the theme block — only ask when the theme is on.
    if [ "$WANT_THEME" = true ]; then
        local header
        header=$(prefix_printf "$(bullet_action)" 'Select Limine menu font (default: spleen):\n')
        LIMINE_FONT=$(gum choose --cursor='      > '  \
                                 --header="${header}" \
                                 --limit=1            \
                                 'spleen' 'terminus' 'profont' 'default') || LIMINE_FONT='spleen'
        printf_action "Limine menu font: ${STYLE_CLR}${LIMINE_FONT}\n"
    fi

    return 0
}


install_limine() {
    #
    # Everything Limine under one section: the official package, the AUR
    # companions, the bootloader binary + its pacman hook, limine.conf, the
    # menu font, the NVRAM entry, /etc/default/limine, and the post.d boot
    # hooks. Each step keeps its own
    # action_request_permission — a silent no-op while sudo is cached, but it
    # re-asserts privilege right before its work (the AUR build can outlast the
    # sudo timestamp) and documents that step's intent.
    #
    printf_section "Installing Limine\n"

    action_require_package 'limine'

    install_aur_tools
    install_limine_bootloader
    write_limine_config
    deploy_menu_font
    register_limine_nvram
    install_sync_defaults
    install_boot_hooks
}


verify_prerequisites() {
    #
    # Pre-flight checks. Each step is an action_run so the section is never
    # empty: failure renders a red status, the trailing exit gives the
    # diagnostic. Sets ESP_DISK / ESP_IDX for the NVRAM entry.
    #
    printf_section "Verifying Prerequisites\n"

    action_request_permission 'to inspect the system'

    # 1. yay present (AUR tools build only as a normal user)
    if ! action_run "AUR helper ${STYLE_CLR}yay"  \
                    'command -v yay'              \
                    'present'                     \
                    'missing'; then
        printf_error "yay not found - run install-yay first\n"
        exit 1
    fi

    # 2. UEFI boot mode (efibootmgr needs it)
    if ! action_run 'UEFI boot mode'        \
                    '[ -d /sys/firmware/efi ]' \
                    'yes'                   \
                    'no'; then
        printf_error "not booted in UEFI mode - can't register Limine in NVRAM\n"
        exit 1
    fi

    # 3. ESP mounted at /boot
    local esp_part
    esp_part=$(detect_esp_mount)
    if ! action_run "ESP mounted at ${STYLE_CLR}/boot"  \
                    "[ -n '$esp_part' ]"                \
                    'mounted'                           \
                    'missing'; then
        printf_error "ESP not mounted at /boot - mount it and re-run\n"
        exit 1
    fi

    local disk_part
    disk_part=$(parse_disk_part "$esp_part")
    ESP_DISK="${disk_part%|*}"
    ESP_IDX="${disk_part##*|}"
    if [ -z "$ESP_DISK" ] || [ -z "$ESP_IDX" ]; then
        printf_error "can't parse ESP partition path: %s\n" "$esp_part"
        exit 1
    fi
    printf_action "ESP: ${STYLE_CLR}%b ${STYLE_DIM}(disk ${STYLE_CLR}%b${STYLE_DIM}, part ${STYLE_CLR}%b${STYLE_DIM})\n" \
        "$(gum style --foreground "$GUM_YELLOW" "$esp_part")"  \
        "$(gum style --foreground "$GUM_YELLOW" "$ESP_DISK")"  \
        "$(gum style --foreground "$GUM_YELLOW" "$ESP_IDX")"

    # 4. root is btrfs subvol=@
    export -f is_root_btrfs_subvol_at
    if ! action_run 'Root filesystem (btrfs subvol=@)'  \
                    'is_root_btrfs_subvol_at'           \
                    'btrfs subvol=@'                    \
                    'mismatch'; then
        printf_error "/ is not btrfs subvol=@ - snapshots require the configure-disk layout\n"
        exit 1
    fi

    # 5. UKI present (built by configure-boot); /boot is root-only (umask 0077)
    if ! action_run "UKI ${STYLE_CLR}${UKI_PATH}"  \
                    "as_root test -f '$UKI_PATH'"  \
                    'present'                      \
                    'missing'; then
        printf_error "UKI not found at ${UKI_PATH} - run configure-boot first\n"
        exit 1
    fi

    # 6. kernel cmdline present (written by configure-boot) — fills //Current
    if ! action_run "Kernel cmdline ${STYLE_CLR}/etc/kernel/cmdline"  \
                    'as_root test -s /etc/kernel/cmdline'             \
                    'present'                                         \
                    'missing'; then
        printf_error "/etc/kernel/cmdline not found - run configure-boot first\n"
        exit 1
    fi

    # 7. cryptroot mapper present — its UUID anchors the holder fstab lines, and
    #    holders are siblings on this btrfs. (Missing holders are provisioned
    #    later, so there's no fstab-presence gate here.)
    if ! action_run "Cryptroot mapper ${STYLE_CLR}${CRYPT_DEV}"  \
                    "as_root test -e '$CRYPT_DEV'"              \
                    'present'                                   \
                    'missing'; then
        printf_error "${CRYPT_DEV} not open - snapshots require the configure-disk layout\n"
        exit 1
    fi

    CRYPT_UUID=$(as_root blkid -s UUID -o value "$CRYPT_DEV" 2>>"$LOG_FILE")
    [ -z "$CRYPT_UUID" ] && assert 1 "can't read UUID for ${CRYPT_DEV}"
    printf_action "Cryptroot UUID: ${STYLE_CLR}${CRYPT_UUID}\n"

    printf_action 'Proceed? '
    ask_yn || exit 0
}


install_aur_tools() {
    #
    # Build + install the AUR companions with yay (runs as the normal user;
    # yay shells out to sudo pacman internally, so cache the password first).
    # Step of the "Installing Limine" section.
    #
    action_request_permission 'to install AUR packages with yay'
    action_run "Install $(gum style --foreground "$GUM_YELLOW" "$AUR_TOOLS")"  \
        "yay -S --needed --noconfirm ${AUR_TOOLS}"                             \
        'done'
    assert $? "can't install AUR snapshot tools"
}


install_limine_bootloader() {
    #
    # Seed the ESP with the Limine binary and install the pacman hook that
    # redeploys it on every limine upgrade. Step of the "Installing Limine"
    # section.
    #
    action_request_permission 'to deploy Limine to the ESP'
    action_run "Create ${STYLE_CLR}/boot/EFI/limine"  \
        'as_root mkdir -p /boot/EFI/limine'           \
        'done'
    assert $? "can't create /boot/EFI/limine"

    action_install_file '/etc/pacman.d/hooks/99-limine.hook' "$LIMINE_HOOK_URL" "$(check_sudo)"

    action_run "Deploy ${STYLE_CLR}${LIMINE_EFI_DST##*/}${STYLE_DIM} to the ESP"  \
        "as_root cp '$LIMINE_EFI_SRC' '$LIMINE_EFI_DST' && as_root sync"          \
        'done'
    assert $? "can't deploy ${LIMINE_EFI_DST}"
}


# shellcheck disable=SC2329
build_limine_conf() {
    #
    # Assemble the Limine config into $tmp: the theme (if selected) goes first
    # so it sits above the settings + boot entries — same order as the manual
    # install (save the theme, then append the config). The '>>' redirects stay
    # inside this function so action_run's appended '&>> LOG' can't clobber them.
    #
    local tmp="$1" want_theme="$2" theme_url="$3" conf_url="$4"

    if [ "$want_theme" = true ]; then
        curl -fsSL "$theme_url" >> "$tmp" || return 1
    fi
    curl -fsSL "$conf_url" >> "$tmp" || return 1
}


# shellcheck disable=SC2329
fill_kernel_cmdline() {
    #
    # Replace the kernel_cmdline placeholder in the assembled config ($1) with the
    # literal contents of /etc/kernel/cmdline, so //Current — and every snapshot
    # limine-snapper-sync clones from it — carries the real cmdline. Pure-bash
    # substitution: the cmdline holds '=', '/', '.' (and maybe '&'/'\') that a
    # sed/awk replacement would mangle, and it must not ride into a bash -c string.
    # /etc/kernel/cmdline is written by configure-boot and gated in verify_prerequisites.
    #   $1 conf - assembled config (user-owned temp)
    #
    local conf="$1"
    local placeholder='<put /etc/kernel/cmdline content>'
    local cmdline body

    cmdline=$(as_root cat /etc/kernel/cmdline 2>>"$LOG_FILE") || return 1
    [ -n "$cmdline" ] || return 1
    body=$(< "$conf") || return 1
    printf '%s\n' "${body/"$placeholder"/$cmdline}" > "$conf"
}


write_limine_config() {
    #
    # Assemble limine.conf (theme first when selected, then settings + boot
    # entries), fill //Current's kernel_cmdline from /etc/kernel/cmdline, then
    # drop the stale deep config under EFI/limine/. Confirms + backs up an
    # existing config first. Step of
    # the "Installing Limine" section.
    #
    action_request_permission 'to write /boot/limine.conf'

    # An existing config means a prior setup — confirm before clobbering it, and
    # keep a backup if we proceed. /boot is root-only (umask 0077), so the
    # existence test needs root.
    if is_package_installed 'limine' && as_root test -f "$LIMINE_CONF"; then
        printf_action "%b ${STYLE_DIM}${LIMINE_CONF} already exists${STYLE_CLR}\n" \
            "$(bullet_info)"
        printf_action 'Back up and replace? '
        if ! ask_yn; then
            printf_action "%b ${STYLE_DIM}keeping existing config — skipping${STYLE_CLR}\n" \
                "$(bullet_info)"
            return 0
        fi

        local backup_name
        backup_name=$(backup_file "$LIMINE_CONF" "$(check_sudo)")
        assert $? "can't back up $LIMINE_CONF"
        [ -n "$backup_name" ] && printf_action "Backup created: ${STYLE_CLR}${backup_name}\n"
    fi

    # Assemble into a temp: theme leads (if selected), settings + entries follow.
    local conf_tmp
    conf_tmp=$(mktemp)
    assert $? "can't create temporary file"

    export -f build_limine_conf
    action_run 'Assemble limine.conf'                                                        \
        "build_limine_conf '$conf_tmp' '$WANT_THEME' '$LIMINE_THEME_URL' '$LIMINE_CONF_URL'"  \
        'done'
    assert $? "can't assemble limine.conf"

    export -f fill_kernel_cmdline
    action_run 'Embed kernel cmdline into //Current'  \
        "fill_kernel_cmdline '$conf_tmp'"             \
        'done'
    assert $? "can't embed /etc/kernel/cmdline into limine.conf"

    action_run "Install ${STYLE_CLR}${LIMINE_CONF}"   \
        "$(check_sudo) cp '$conf_tmp' '$LIMINE_CONF'" \
        'done'
    assert $? "can't install $LIMINE_CONF"
    rm -f "$conf_tmp"

    action_run "Remove stale ${STYLE_CLR}${DEEP_LIMINE_CONF}"  \
        "as_root rm -f '$DEEP_LIMINE_CONF'"                    \
        'done'
    assert $? "can't remove $DEEP_LIMINE_CONF"
}


# shellcheck disable=SC2329
use_builtin_menu_font() {
    #
    # Drop the external-bitmap directives so Limine falls back to its built-in
    # font. term_font_scale stays — it scales the built-in font too.
    #   $1 conf    - limine.conf path
    #   $2 prefix  - sudo prefix (from check_sudo)
    #
    remove_line "$1" '^term_font:' "$2" && remove_line "$1" '^term_font_size:' "$2"
}


deploy_menu_font() {
    #
    # Point the Limine menu at the selected font. The term_font directive lives
    # in the theme block, so this is a no-op without the theme. 'default' keeps
    # Limine's built-in font (no bitmap); the named fonts deploy their raw bitmap
    # to the ESP root and, when not the baked-in spleen, repoint term_font. Folds
    # under the "Installing Limine" section.
    #
    [ "$WANT_THEME" = true ] || return 0

    action_request_permission 'to set the Limine menu font'

    if [ "$LIMINE_FONT" = 'default' ]; then
        export -f use_builtin_menu_font
        action_run 'Use built-in Limine menu font'                 \
            "use_builtin_menu_font '$LIMINE_CONF' '$(check_sudo)'"  \
            'done'
        assert $? "can't drop term_font lines in $LIMINE_CONF"
        return 0
    fi

    local font_file="${LIMINE_FONT}-8x16.bin"
    action_install_file "/boot/${font_file}" "${LIMINE_FONT_BASE_URL}/${font_file}" "$(check_sudo)"

    # Only spleen is baked into limine-theme.conf — repoint term_font for the rest.
    if [ "$LIMINE_FONT" != 'spleen' ]; then
        action_run "Point ${STYLE_CLR}term_font${STYLE_DIM} at ${STYLE_CLR}${font_file}"                  \
            "replace_line '$LIMINE_CONF' '^term_font:.*' 'term_font: boot():/${font_file}' $(check_sudo)"  \
            'done'
        assert $? "can't repoint term_font in $LIMINE_CONF"
    fi
}


register_limine_nvram() {
    #
    # Register Limine as a separate NVRAM entry, then reorder so the UKI boots
    # first and Limine second. Idempotent: skip create if the entry exists. Step
    # of the "Installing Limine" section.
    #
    action_require_package 'efibootmgr'
    action_request_permission 'to manage NVRAM boot entries'

    if as_root efibootmgr 2>>"$LOG_FILE" | grep -qF "$LIMINE_LABEL"; then
        printf_action "%b ${STYLE_DIM}entry ${STYLE_CLR}${LIMINE_LABEL}${STYLE_DIM} already present — skipping create${STYLE_CLR}\n" \
            "$(bullet_info)"
    else
        action_run "Register $(gum style --foreground "$GUM_YELLOW" "$LIMINE_LABEL")"  \
            "as_root efibootmgr --create --disk '$ESP_DISK' --part $ESP_IDX            \
                                --label '$LIMINE_LABEL'                                \
                                --loader '$LIMINE_LOADER' --unicode"                   \
            'done'
        assert $? "can't register Limine in NVRAM"
    fi

    export UKI_LABEL LIMINE_LABEL
    export -f reorder_bootorder
    if ! action_run 'Reorder boot entries (UKI first, Limine second)'  \
                    'reorder_bootorder'                                \
                    'done'                                             \
                    'UKI entry not found'; then
        printf_action "%b ${STYLE_DIM}reorder skipped — set it manually: ${STYLE_CLR}efibootmgr --bootorder <UKI>,<Limine>,…${STYLE_CLR}\n" \
            "$(bullet_warning)"
    fi
}


install_sync_defaults() {
    #
    # /etc/default/limine drives limine-snapper-sync + limine-mkinitcpio-hook.
    # Step of the "Installing Limine" section.
    #
    action_request_permission 'to write /etc/default/limine'
    action_install_file '/etc/default/limine' "$LIMINE_DEFAULT_URL" "$(check_sudo)"
}


install_boot_hooks() {
    #
    # Install the post.d hooks limine-snapper-sync runs after it rewrites
    # limine.conf: 81-limine-strip-resume (always — idempotent, a no-op without
    # hibernation) and, when selected, 80-limine-flatten-snapshots. Must land
    # before the initial sync so the first written config is already scrubbed.
    # action_install_file neither creates the dir nor sets the exec bit, so do
    # both here. Step of the "Installing Limine" section.
    #
    action_request_permission 'to install limine post.d hooks'

    action_run "Create ${STYLE_CLR}${BOOT_HOOKS_DIR}"  \
        "as_root mkdir -p '${BOOT_HOOKS_DIR}'"         \
        'done'
    assert $? "can't create ${BOOT_HOOKS_DIR}"

    # strip-resume: always (hibernation safety; harmless when no resume= present)
    local strip_dst="${BOOT_HOOKS_DIR}/81-limine-strip-resume"
    action_install_file "$strip_dst" "$LIMINE_STRIP_HOOK_URL" "$(check_sudo)"
    action_run "Make ${STYLE_CLR}${strip_dst##*/}${STYLE_DIM} executable"  \
        "as_root chmod +x '$strip_dst'"                                    \
        'done'
    assert $? "can't chmod +x $strip_dst"

    # flatten: optional
    if [ "$WANT_FLATTEN" = true ]; then
        local flat_dst="${BOOT_HOOKS_DIR}/80-limine-flatten-snapshots"
        action_install_file "$flat_dst" "$LIMINE_FLATTEN_HOOK_URL" "$(check_sudo)"
        action_run "Make ${STYLE_CLR}${flat_dst##*/}${STYLE_DIM} executable"  \
            "as_root chmod +x '$flat_dst'"                                    \
            'done'
        assert $? "can't chmod +x $flat_dst"
    fi
}


# shellcheck disable=SC2329
fstab_append() {
    #
    # Append a line to /etc/fstab unless a line matching the regex pattern is
    # already present. prefix (e.g. sudo) elevates the read + append.
    #
    local pattern="$1"
    local line="$2"
    local prefix="${3-}"

    ${prefix} grep -qE "${pattern}" /etc/fstab && return 0
    printf '\n%s\n' "${line}" | ${prefix} tee -a /etc/fstab &>> "$LOG_FILE"
}


ensure_holder() {
    #
    # Make sure the snapshot-holder subvolume and its fstab entry exist, creating
    # them when missing (configure-disk normally provisions them; this covers the
    # case it didn't). Idempotent.
    #
    #   $1 subvol  - sibling holder subvolume (@snapshots | @home-snapshots)
    #   $2 snapdir - its mountpoint (/.snapshots | /home/.snapshots)
    #
    local subvol="$1" snapdir="$2"

    # Create the sibling subvolume if absent. It can't be made from inside @, so
    # mount the btrfs top-level (subvolid=5) at a temp mountpoint.
    if as_root btrfs subvolume list / 2>>"$LOG_FILE" | grep -qE "[[:space:]]path ${subvol}$"; then
        printf_action "%b ${STYLE_DIM}subvolume ${STYLE_CLR}${subvol}${STYLE_DIM} exists${STYLE_CLR}\n" \
            "$(bullet_info)"
    else
        local top
        top=$(mktemp -d)
        assert $? "can't create temp mountpoint"

        action_run "Mount cryptroot top-level at ${STYLE_CLR}${top}"  \
            "as_root mount -o subvolid=5 '$CRYPT_DEV' '$top'"         \
            'done'
        assert $? "can't mount cryptroot top-level"

        action_run "Create subvolume ${STYLE_CLR}${subvol}"  \
            "as_root btrfs subvolume create '$top/$subvol'"  \
            'done'
        assert $? "can't create $subvol"

        action_run "Unmount top-level ${STYLE_CLR}${top}"  \
            "as_root umount '$top'"                        \
            'done'                                         \
            'busy'
        assert $? "can't unmount $top"

        rmdir "$top" 2>>"$LOG_FILE"
    fi

    # Add the fstab entry if missing. btrfs-wide options are inherited from @'s
    # mount, so only subvol= + noatime are needed. Tolerate a slash-prefixed
    # subvol=/@... that genfstab/configure-disk may already have written.
    local fstab_line="UUID=${CRYPT_UUID}  ${snapdir}  btrfs  subvol=${subvol},noatime  0 0"
    local fstab_pattern="subvol=/?${subvol}([,[:space:]]|\$)"

    export -f fstab_append
    action_run "Add fstab entry for ${STYLE_CLR}${snapdir}"             \
        "fstab_append '${fstab_pattern}' '${fstab_line}' $(check_sudo)" \
        'done'
    assert $? "can't add fstab entry for $snapdir"

    action_run 'Reload systemd unit cache'      \
        "$(check_sudo) systemctl daemon-reload" \
        'done'
    assert $? 'daemon-reload failed'
}


configure_snapper_config() {
    #
    # Create a snapper config, swap snapper's throwaway nested .snapshots for
    # the sibling holder, set permissions, and apply retention. Provisions the
    # holder first. Idempotent: skips the create dance when the config exists.
    #
    #   $1 cfg          - snapper config name (root | home)
    #   $2 target       - subvolume mountpoint (/ | /home)
    #   $3 snapdir      - sibling .snapshots mountpoint
    #   $4 subvol       - sibling holder subvolume (@snapshots | @home-snapshots)
    #   $5 retention_fn - exported function applying the retention policy
    #
    local cfg="$1" target="$2" snapdir="$3" subvol="$4" retention_fn="$5"

    printf_section "Configuring Snapper for ${STYLE_CLR}%b\n"  \
        "$(gum style --foreground "$GUM_YELLOW" "$target")"

    action_request_permission "to configure snapper for ${target}"

    # snapper is installed once here (root always runs first and is mandatory);
    # the home pass reuses it. create-config needs it; ensure_holder doesn't.
    if [ "$cfg" = 'root' ]; then
        action_require_package 'snapper'
    fi

    # Make sure the holder subvolume + its fstab line exist before the dance.
    ensure_holder "$subvol" "$snapdir"

    if as_root snapper list-configs 2>>"$LOG_FILE" | grep -qw "$cfg"; then
        printf_action "%b ${STYLE_DIM}config ${STYLE_CLR}${cfg}${STYLE_DIM} exists — skipping create-config${STYLE_CLR}\n" \
            "$(bullet_info)"
    else
        # If the holder is currently mounted (pre-provisioned), unmount it so
        # create-config can make — and we can delete — its throwaway subvol.
        if mountpoint -q "$snapdir"; then
            action_run "Unmount sibling holder ${STYLE_CLR}${snapdir}"   \
                "as_root umount '$snapdir' && as_root rm -rf '$snapdir'" \
                'done'                                                   \
                'busy'
            assert $? "can't unmount $snapdir"
        fi

        action_run "Create snapper config ${STYLE_CLR}${cfg}"   \
            "as_root snapper -c '$cfg' create-config '$target'" \
            'done'
        assert $? "can't create snapper config $cfg"

        action_run "Delete throwaway subvolume ${STYLE_CLR}${snapdir}"  \
            "as_root btrfs subvolume delete '$snapdir'"                 \
            'done'
        assert $? "can't delete throwaway subvolume at $snapdir"

        action_run "Create mountpoint ${STYLE_CLR}${snapdir}"  \
            "as_root mkdir '$snapdir'"                         \
            'done'
        assert $? "can't create $snapdir"

        action_run "Mount sibling holder at ${STYLE_CLR}${snapdir}"  \
            "as_root mount '$snapdir'"                               \
            'done'
        assert $? "can't mount $snapdir (is the fstab entry present?)"
    fi

    action_run "Set ${STYLE_CLR}${snapdir}${STYLE_DIM} ownership and mode"  \
        "as_root chmod 750 '$snapdir' && as_root chown :wheel '$snapdir'"   \
        'done'
    assert $? "can't set permissions on $snapdir"

    action_run "Apply ${STYLE_CLR}${cfg}${STYLE_DIM} retention policy"  \
        "$retention_fn"                                                 \
        'done'
    assert $? "can't apply $cfg retention"

    # snap-pac walks SNAPPER_CONFIGS; create-config adds the config there.
    if [ "$cfg" = 'root' ]; then
        action_run 'Verify snap-pac wired (SNAPPER_CONFIGS)'  \
            "as_root grep -qw 'root' /etc/conf.d/snapper"     \
            'root'                                            \
            'missing'
    fi
}


enable_limine_snapper_sync() {
    #
    # Run an initial sync (best-effort) and enable the inotify-driven service
    # that turns each new snapshot into a Limine boot entry. Folds under the
    # "Configuring Snapper for /" section (prints no header of its own).
    #
    action_request_permission 'to enable limine-snapper-sync'

    # May find nothing to do before the first snapshot — never fatal.
    action_run 'Run initial sync (best-effort)'   \
        'as_root limine-snapper-sync || true'     \
        'done'

    action_run 'Enable limine-snapper-sync.service'                  \
        'as_root systemctl enable --now limine-snapper-sync.service' \
        'enabled'
    assert $? "can't enable limine-snapper-sync.service"
}


install_snap_pac() {
    #
    # Install snap-pac LAST — it's the trigger that turns each pacman
    # transaction into a snapper pre/post pair. Installing it only now, with the
    # root config registered and the limine-snapper-sync watcher live, keeps the
    # configuration's own package installs from creating snapshots before the
    # pipeline is ready. (alpm fixes the hook set at transaction start, so
    # snap-pac never snapshots its own install — the first pair fires on the
    # user's next pacman -Syu.) Folds under the "Configuring Snapper for /"
    # section as its final action.
    #
    action_require_package 'snap-pac'
}


enable_timeline_timer() {
    #
    # One timer walks every config with TIMELINE_CREATE=yes (just 'home' here).
    # Folds under the "Configuring Snapper for /home" section (prints no header
    # of its own).
    #
    action_request_permission 'to enable snapper-timeline.timer'
    action_run 'Enable snapper-timeline.timer'                  \
        'as_root systemctl enable --now snapper-timeline.timer' \
        'enabled'
    assert $? "can't enable snapper-timeline.timer"
}


main() {

    ## Refuse to run as root
    # yay / makepkg cannot build as root; privileged steps use as_root instead.
    if [ "$EUID" -eq 0 ]; then
        printf_error "%b\n" 'this script must be run as a non-root user (AUR tools cannot build as root)'
        exit 1
    fi

    ## Get gum

    request_gum
    assert $? 'no gum - no fun :('

    ## Init

    printf_section "Starting\n"
    printf_action "Common lib version: ${STYLE_CLR}${COMMON_VERSION}\n"
    start_logger
    printf_action "Log started: ${STYLE_CLR}${LOG_FILE}\n"

    ## Optional components

    select_optional_components || return 0

    ## Pre-flight

    verify_prerequisites

    ## Limine — bootloader, AUR tools, config, NVRAM, sync defaults (one section)

    install_limine

    ## Snapper — per-target configs, sync service, snap-pac trigger, timer

    # Retention helpers run inside action_run's bash -c subshell — export them.
    export -f apply_root_retention apply_home_retention

    # root (mandatory): enable_limine_snapper_sync + install_snap_pac print no
    # header — they fold under "Configuring Snapper for /". snap-pac is last.
    configure_snapper_config 'root' '/' '/.snapshots' '@snapshots' 'apply_root_retention'
    enable_limine_snapper_sync
    install_snap_pac

    # home (optional): enable_timeline_timer folds under its section.
    if [ "$WANT_HOME" = true ]; then
        configure_snapper_config 'home' '/home' '/home/.snapshots' '@home-snapshots' 'apply_home_retention'
        enable_timeline_timer
    fi

    ## Closing tips

    printf_info "%b\n" 'reboot to confirm the Limine menu, then run pacman -Syu to trigger the first snapshot pair'
    printf_info "%b\n" 'after the first sync: grep -i resume /boot/limine.conf — resume= must show only on //Current'

    return 0
}


main "$@"
