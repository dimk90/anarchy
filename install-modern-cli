}


install_eza() {
    printf_section "eza\n"
    action_require_package 'eza'

    # Install custom theme
    mkdir -p ~/.config/eza
    action_install_file ~/.config/eza/theme.yml \
        'https://dimk90.github.io/anarchy/cli/eza-theme.yml'

    # Configure alias for eza
    local shells
    # shellcheck disable=SC2034
    shells=$(alias_set_permanent 'ls' 'eza')
    action_run 'Set alias: ls' '' "${shells}"
    # shellcheck disable=SC2034
    shells=$(alias_set_permanent 'll' 'eza -lahF --icons --group-directories-first --git --header')
    action_run 'Set alias: ll' '' "${shells}"
    # shellcheck disable=SC2034
    shells=$(alias_set_permanent 'll-size' 'll --total-size')
    action_run 'Set alias: ll-size' '' "${shells}"
    # shellcheck disable=SC2034
    shells=$(alias_set_permanent 'lt' 'll --tree --level=2')
    action_run 'Set alias: lt' '' "${shells}"
    # shellcheck disable=SC2034
    shells=$(alias_set_permanent 'lt-size' 'lt --total-size')
    action_run 'Set alias: lt-size' '' "${shells}"
}


install_fzf() {
