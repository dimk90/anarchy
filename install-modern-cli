# shellcheck disable=SC2329
bash_enable_zoxide() {
    config_set_param ~/.bashrc 'eval "\$\(zoxide init --cmd j bash\)"'
}

# shellcheck disable=SC2329
fish_enable_zoxide() {
    config_set_param ~/.config/fish/config.fish 'zoxide init --cmd j fish \| source'
}

# shellcheck disable=SC2329
fish_add_help_colorization() {
    config_set_param ~/.config/fish/config.fish \
        "abbr -a --position anywhere -- --help '--help \| bat -plhelp --theme TwoDark'"

    # Note: potential conflict with some commands
    #       which use -h not for help, e.g. ls -h
    config_set_param ~/.config/fish/config.fish \
        "abbr -a --position anywhere -- -h '-h \| bat -plhelp --theme TwoDark'"
}


install_zoxide() {
    printf_section "zoxide\n"
    action_require_package 'zoxide'

    # Enable for fish and bash
    export -f bash_enable_zoxide
    action_run 'Enable zoxide for bash' 'bash_enable_zoxide' 'done'

    if is_command_available 'fish'; then
        export -f fish_enable_zoxide
        action_run 'Enable zoxide for fish' 'fish_enable_zoxide' 'done'
    fi

    # Add alias for cd

    # shellcheck disable=SC2155
    local shells=$(alias_set_permanent 'cd' 'j')
    action_run 'Set alias cd->zoxide' '' "${shells}"

    # shellcheck disable=SC2155
    shells=$(alias_set_permanent 'cdi' 'ji')
    action_run 'Set alias cdi->zoxide(interactive)' '' "${shells}"
}


install_less() {
    printf_section "less\n"
    action_require_package 'less'

    # Set as default pager
    shells=$(env_set_permanent 'PAGER' 'less')
    action_run 'Set less as default pager' '' "${shells}"

    # Set default options
    shells=$(alias_set_permanent 'less' 'less -RFXi --mouse')
    action_run 'Set default options' '' "${shells}"
}


install_bash_completion() {
    printf_section "bash-completion\n"
    action_require_package 'bash-completion'
}


install_bat() {
    printf_section "bat\n"
    action_require_package 'bat'

    # Install config
    mkdir -p ~/.config/bat
    assert $? 'Failed to create config directory for bat'
    action_install_file ~/.config/bat/config \
        'https://dimk90.github.io/anarchy/cli/bat.cfg'

    # Set alias for cat
    local shells
    shells=$(alias_set_permanent 'cat' 'bat')
    action_run 'Set alias cat->bat' '' "${shells}"

    # Use bat for man colorization
    shells=$(env_set_permanent 'MANPAGER' 'bat -plman --theme TwoDark')
    action_run 'Register bat for man colorization' '' "${shells}"

    # Add --help colorization
    if is_command_available 'fish'; then
        export -f fish_add_help_colorization
        action_run 'Add --help colorization' 'fish_add_help_colorization' 'fish shell'
    fi
}


install_fd() {
