#!/bin/bash

# Treat unset variables as an error and exit immediately
set -o nounset


## Imports


set -o errexit # exit on non-zero exit code
COMMON=$(curl -fsSL "https://dimk90.github.io/anarchy/common")
# shellcheck source=common
source <(echo "$COMMON")

set +o errexit # disable exit on non-zero exit code


## Routines


# shellcheck disable=SC2329
bash_enable_zoxide() {
    config_set_param ~/.bashrc 'eval "\$\(zoxide init --cmd j bash\)"'
}

# shellcheck disable=SC2329
fish_enable_zoxide() {
    config_set_param ~/.config/fish/config.fish 'zoxide init --cmd j fish \| source'
}

# shellcheck disable=SC2329
fish_add_help_colorization() {
    # Note: there is an issue with running bat+less for fish native functions
    #       like set -h, export -h, etc. The screen scroll doesn't work and
    #       print keycodes instead. That is unsolved problem:
    #       - https://github.com/sharkdp/bat/issues/1006
    # The help() function is a temporary workaround
    config_set_param ~/.config/fish/config.fish \
        "abbr -a --position anywhere -- --help '--help \| bat -plhelp --theme TwoDark'"

    # Note: potential conflict with some commands
    #       which use -h not for help, e.g. ls -h
    config_set_param ~/.config/fish/config.fish \
        "abbr -a --position anywhere -- -h '-h \| bat -plhelp --theme TwoDark'"
}

# shellcheck disable=SC2329
fzf_configure_default() {
    # Run directory scan with fd by default
    env_set_permanent 'FZF_DEFAULT_COMMAND' \
        'fd --color=always --hidden --follow -E .git -E .env -E .venv -E .cache'

    # Note: color theme playground: https://vitormv.github.io/fzf-themes/
    env_set_permanent 'FZF_DEFAULT_OPTS' \
        '--ansi --cycle --multi --layout=reverse --border top --preview-border left --padding="0,1,1,0" --height=80% --prompt="Filter> " --marker="+ " --pointer="|" --info="right" --color=fg:-1,fg+:#d0d0d0,bg:-1,hl:#5f87af,hl+:#5fd7ff,info:#afaf87,marker:#60F090,prompt:#00F0B0,spinner:#87ff00,pointer:#60F090,header:#87afaf,border:#404040,label:#aeaeae,query:#d9d9d9'
}

fish_install_fzf_plugin() {
    local tmpdir
    tmpdir=$(mktemp -d) || return 1
    git clone https://github.com/PatrickF1/fzf.fish "$tmpdir" || { rm -rf "$tmpdir"; return 1; }
    rm -rf ~/.config/fish/plugins/fzf.fish
    mkdir -p ~/.config/fish/plugins || return 1
    mv "$tmpdir" ~/.config/fish/plugins/fzf.fish || return 1
    # Symlink the plugin files into fish config dirs
    ln -sf ~/.config/fish/plugins/fzf.fish/functions/*    ~/.config/fish/functions/   || return 1
    ln -sf ~/.config/fish/plugins/fzf.fish/conf.d/*       ~/.config/fish/conf.d/      || return 1
    ln -sf ~/.config/fish/plugins/fzf.fish/completions/*  ~/.config/fish/completions/ || return 1
    # Adjust some keybindings
    # Note: must be single call to fzf_configure_bindings
    config_set_param ~/.config/fish/config.fish 'fzf_configure_bindings --variables=ctrl-alt-v --history=ctrl-alt-h'
    # Adjust preview command and fd options
    config_set_param ~/.config/fish/config.fish 'set fzf_preview_dir_cmd ll --color=always'
    config_set_param ~/.config/fish/config.fish 'set fzf_fd_opts --color=always --hidden --follow -E .git -E .env -E .venv -E .cache'
    # Fix border style for fzf-ps and fzf-history
    # shellcheck disable=SC1003
    sed -i '/--preview-window=/a\            --preview-border="top" \\' \
        ~/.config/fish/plugins/fzf.fish/functions/_fzf_search_history.fish
    # shellcheck disable=SC1003
    sed -i '/--preview-window=/a\                    --preview-border="top" \\' \
        ~/.config/fish/plugins/fzf.fish/functions/_fzf_search_processes.fish
}

# shellcheck disable=SC2329
fzf_install_fish_aliases() {
    local FZF_ALIASES=(
        fzf-fd
        fzf-ps
        fzf-history
        fzf-env
        fzf-git-log
        fzf-git-status
    )

    mkdir -p ~/.config/fish/functions || return 1

    for alias in "${FZF_ALIASES[@]}"; do
        action_install_file "$HOME/.config/fish/functions/${alias}.fish" \
            "https://dimk90.github.io/anarchy/cli/${alias}.fish"
    done
}

# shellcheck disable=SC2329
fzf_install_bash_aliases() {
    mkdir -p ~/.config/bash || return 1
    action_install_file ~/.config/bash/fzf-aliases.bash \
        'https://dimk90.github.io/anarchy/cli/fzf-aliases.bash'
    config_set_param ~/.bashrc 'source ~/\.config/bash/fzf-aliases\.bash'
}


# shellcheck disable=SC2329
delta_git_integration() {
    # Use delta as the default pager for diff, log, show, etc.
    git config --global core.pager "delta"
    # Syntax-highlight diffs in interactive commands (add -p, stash -p)
    git config --global interactive.diffFilter "delta --color-only"
    # Show base, ours, and theirs in merge conflict markers
    git config --global merge.conflictStyle zdiff3
    # Enable n/N keybindings to jump between diff sections
    git config --global delta.navigate true
    # Emit OSC 8 terminal hyperlinks for file paths
    git config --global delta.hyperlinks true
    # Open hyperlinked files directly in VS Code at the specific line
    git config --global delta.hyperlinks-file-link-format "vscode://file/{path}:{line}"
}

# shellcheck disable=SC2329
delta_set_theme() {
    git config --global include.path "$HOME/.config/delta/theme.gitconfig"
    git config --global delta.features "common lindworm"
}

# shellcheck disable=SC2329
delta_fzf_integration() {
    config_set_param ~/.config/fish/config.fish 'set fzf_diff_highlighter delta --paging=never --features \\"fzf lindworm\\"'
}

# shellcheck disable=SC2329
delta_install_theme() {
    mkdir -p ~/.config/delta
    assert $? 'Failed to create config directory for delta'

    action_install_file ~/.config/delta/theme.gitconfig \
        'https://dimk90.github.io/anarchy/cli/theme.gitconfig'

    export -f delta_set_theme
    action_run 'Set color theme: lindworm' 'delta_set_theme' 'done'
}


install_zoxide() {
    printf_section "zoxide\n"
    action_require_package 'zoxide'

    # Enable for fish and bash
    export -f bash_enable_zoxide
    action_run 'Enable zoxide for bash' 'bash_enable_zoxide' 'done'

    if is_command_available 'fish'; then
        export -f fish_enable_zoxide
        action_run 'Enable zoxide for fish' 'fish_enable_zoxide' 'done'
    fi

    # Add alias for cd

    # shellcheck disable=SC2155
    local shells=$(alias_set_permanent 'cd' 'j')
    action_run 'Set alias cd->zoxide' '' "${shells}"

    # shellcheck disable=SC2155
    shells=$(alias_set_permanent 'cdi' 'ji')
    action_run 'Set alias cdi->zoxide(interactive)' '' "${shells}"
}


install_less() {
    printf_section "less\n"
    action_require_package 'less'

    # Set as default pager
    local shells
    shells=$(env_set_permanent 'PAGER' 'less')
    action_run 'Set less as default pager' '' "${shells}"

    # Set default options
    shells=$(alias_set_permanent 'less' 'less -RFXi --mouse')
    action_run 'Set default options' '' "${shells}"
}


install_bash_completion() {
    printf_section "bash-completion\n"
    action_require_package 'bash-completion'
}


install_bat() {
    printf_section "bat\n"
    action_require_package 'bat'

    # Install config
    mkdir -p ~/.config/bat
    assert $? 'Failed to create config directory for bat'
    action_install_file ~/.config/bat/config \
        'https://dimk90.github.io/anarchy/cli/bat.cfg'

    # Set alias for cat
    local shells
    shells=$(alias_set_permanent 'cat' 'bat')
    action_run 'Set alias cat->bat' '' "${shells}"

    # Use bat for man colorization
    shells=$(env_set_permanent 'MANPAGER' 'bat -plman --theme TwoDark')
    action_run 'Register bat for man colorization' '' "${shells}"

    # Add --help colorization
    if is_command_available 'fish'; then
        export -f fish_add_help_colorization
        # Add abbr for -h and --help to colorize help output
        action_run 'Add --help colorization' 'fish_add_help_colorization' 'fish shell'
        # Add help function for colorization and avoiding issue with native fish functions
        action_install_file "$HOME/.config/fish/functions/help.fish" \
            "https://dimk90.github.io/anarchy/cli/help.fish"
    fi
}


install_fd() {
    printf_section "fd\n"
    action_require_package 'fd' '' 'fd-find'

    # Install vivid for LS_COLORS generation
    action_require_package 'vivid'

    # Set LS_COLORS using vivid with tokyonight-storm theme
    local shells
    shells=$(env_set_permanent 'LS_COLORS' "$(vivid generate tokyonight-storm)")
    action_run 'Set fd colors to tokyonight-storm (LS_COLORS via vivid)' '' "${shells}"
}


install_rg() {
    printf_section "ripgrep\n"
    action_require_package 'ripgrep'

    # Set alias for grep
    # shellcheck disable=SC2155
    local shells=$(alias_set_permanent 'grep' 'rg')
    action_run 'Set alias grep->rg' '' "${shells}"
}


install_eza() {
    printf_section "eza\n"
    action_require_package 'eza'

    # Install custom theme
    mkdir -p ~/.config/eza
    assert $? 'Failed to create config directory for eza'
    action_install_file ~/.config/eza/theme.yml \
        'https://dimk90.github.io/anarchy/cli/eza-theme.yml'

    # Configure alias for eza
    local shells
    # shellcheck disable=SC2034
    shells=$(alias_set_permanent 'ls' 'eza')
    action_run 'Set alias: ls' '' "${shells}"
    # shellcheck disable=SC2034
    shells=$(alias_set_permanent 'll' 'eza -lahF --icons --group-directories-first --header')
    action_run 'Set alias: ll' '' "${shells}"
    # shellcheck disable=SC2034
    shells=$(alias_set_permanent 'll-size' 'll --total-size')
    action_run 'Set alias: ll-size' '' "${shells}"
    # shellcheck disable=SC2034
    shells=$(alias_set_permanent 'lt' 'll --tree --level=2')
    action_run 'Set alias: lt' '' "${shells}"
    # shellcheck disable=SC2034
    shells=$(alias_set_permanent 'lt-size' 'lt --total-size')
    action_run 'Set alias: lt-size' '' "${shells}"
}


install_tldr() {
    printf_section "man & tldr\n"
    action_require_package 'man-db'
    action_require_package 'tldr'
}


install_fzf() {
    printf_section "fzf\n"
    action_require_package 'fzf'

    # Configure default command and options (fzf.fish style)
    export -f fzf_configure_default
    action_run 'Configure default options' 'fzf_configure_default' 'done'

    # Install fzf.fish plugin
    if is_command_available 'fish'; then
        export -f fish_install_fzf_plugin
        action_run 'Install fzf.fish plugin (hotkeys)' 'fish_install_fzf_plugin' 'done'
    fi

    # Set fzf aliases
    if is_command_available 'fish'; then
        fzf_install_fish_aliases
    fi

    if is_command_available 'bash'; then
        fzf_install_bash_aliases
    fi
}


install_delta() {
    is_command_available 'git' || return

    printf_section "git-delta\n"
    action_require_package 'git-delta'

    # Configure git to use delta
    export -f delta_git_integration
    action_run 'Configure git integration' 'delta_git_integration' 'done'

    # Configure color theme
    delta_install_theme

    # Configure fzf to use delta as diff highlighter
    if is_command_available 'fzf' && is_command_available 'fish'; then
        export -f delta_fzf_integration
        action_run 'Configure delta for fzf' 'delta_fzf_integration' 'done'
    fi
}


main() {

    ## Get gum

    request_gum
    assert $? 'no gum - no fun :('

    ## Init

    printf_section "Starting\n"
    printf_action "Common lib version: ${STYLE_CLR}${COMMON_VERSION}\n"
    start_logger
    printf_action "Log started: ${STYLE_CLR}${LOG_FILE}\n"

    ## Install CLI

    install_zoxide
    install_less
    install_bash_completion
    install_bat
    install_fd
    install_rg
    install_eza
    install_tldr
    install_fzf
    install_delta

    printf_warning "Restart your shell to apply the new configuration\n"

    return 0
}


main "$@"
