#!/bin/bash

# Treat unset variables as an error and exit immediately
set -o nounset


## Imports


set -o errexit # exit on non-zero exit code

COMMON=$(curl -fsSL "https://dimk90.github.io/anarchy/common")
# shellcheck source=common
source <(echo "$COMMON")

set +o errexit # disable exit on non-zero exit code


## Constants


# Partition layout (sizes from doc/-0- Minimal.md)
ESP_END='512MiB'
BOOT_END='2.5GiB'

# Cryptsetup mapper name for the encrypted root partition
CRYPT_NAME='cryptroot'

# Mount target root (live install convention)
MNT='/mnt'

# Btrfs mount options
BTRFS_OPTS_ROOT='noatime,ssd,compress=zstd:1,space_cache=v2'
BTRFS_OPTS_OTHER='noatime,ssd,commit=120,compress=zstd:1,space_cache=v2'

# Tightened /efi (vfat) mount options for fstab (genfstab leaves "defaults")
EFI_OPTS='defaults,uid=0,gid=0,umask=0077,noatime,nodev,nosuid,noexec,shortname=winnt,nofail'


## Routines


require_tools() {
    #
    # Ensure all required tools are installed.
    #
    printf_section "Checking required tools\n"

    action_require_package 'parted'
    action_require_package 'cryptsetup'
    action_require_package 'btrfs-progs'
    action_require_package 'dosfstools'
    action_require_package 'arch-install-scripts'  # for genfstab
}


list_disks() {
    #
    # Print available disks (one per line) as: <NAME>|<SIZE>|<MODEL>.
    # PAIRS format escapes spaces in MODEL safely for eval.
    #
    local NAME SIZE MODEL TYPE
    while IFS= read -r line; do
        eval "$line"
        # shellcheck disable=SC2154
        if [ "$TYPE" = 'disk' ]; then
            echo "${NAME}|${SIZE}|${MODEL}"
        fi
    done < <(lsblk -dpnP -o NAME,SIZE,MODEL,TYPE)
}


select_disk() {
    #
    # Show available disks and let the user choose one.
    # On success: prints selected disk path on stdout, returns 0.
    # On cancel or empty list: returns 1.
    #
    local disks_info=()
    mapfile -t disks_info < <(list_disks)

    if [ "${#disks_info[@]}" -eq 0 ]; then
        return 1
    fi

    # Build aligned labels: "/dev/sda          500G   WD_BLACK"
    local labels=()
    local entry name size model label
    for entry in "${disks_info[@]}"; do
        IFS='|' read -r name size model <<< "$entry"
        label=$(printf "%-18s %8s   %s" "$name" "$size" "${model:-(unknown)}")
        labels+=("$label")
    done

    local section
    section=$(prefix_printf "$(bullet_section)" 'Select Disk')

    local selected
    selected=$(gum choose --cursor='   > '   \
                          --header "$section" \
                          "${labels[@]}") || return 1

    # Extract path (first whitespace-separated field)
    awk '{print $1}' <<< "$selected"
}


is_disk_empty() {
    #
    # Check if a disk has no partitions and no filesystem signatures.
    # Returns 0 if empty, 1 otherwise.
    #
    local disk="$1"

    # Check for child block devices (partitions, mappers).
    # 'lsblk -lno NAME' lists all entries flat; first row is the disk itself.
    local children
    children=$(lsblk -lno NAME "$disk" 2>>"$LOG_FILE" | tail -n +2)
    if [ -n "$children" ]; then
        return 1
    fi

    # Check for residual filesystem/partition table signatures.
    if [ -n "$(as_root wipefs --no-act "$disk" 2>>"$LOG_FILE" | tail -n +2)" ]; then
        return 1
    fi

    return 0
}


partition_path() {
    #
    # Build the partition device path for a disk and partition index.
    # NVMe-style names (ending with a digit) need a 'p' separator.
    #
    local disk="$1"
    local idx="$2"

    if [[ "$disk" =~ [0-9]$ ]]; then
        echo "${disk}p${idx}"
    else
        echo "${disk}${idx}"
    fi
}


partition_disk() {
    #
    # Create the GPT layout: ESP, /boot, rootfs (per doc/-0- Minimal.md).
    #
    local disk="$1"

    printf_section "Partitioning %b\n" \
        "$(gum style --foreground "$GUM_YELLOW" "$disk")"

    action_request_permission 'to write a new GPT label'
    action_run 'Create GPT label'                 \
        "as_root parted -s '$disk' mklabel gpt"   \
        'done'
    assert $? "can't create GPT label"

    action_run "Create p1: ESP (fat32, 0% .. ${ESP_END})"            \
        "as_root parted -s '$disk' mkpart ESP fat32 0% ${ESP_END}"   \
        'done'
    assert $? "can't create ESP partition"

    action_run 'Set ESP flag on p1'                  \
        "as_root parted -s '$disk' set 1 esp on"     \
        'done'
    assert $? "can't set ESP flag"

    action_run "Create p2: boot (${ESP_END} .. ${BOOT_END})"            \
        "as_root parted -s '$disk' mkpart boot ${ESP_END} ${BOOT_END}"  \
        'done'
    assert $? "can't create boot partition"

    action_run "Create p3: rootfs (${BOOT_END} .. 100%)"              \
        "as_root parted -s '$disk' mkpart rootfs ${BOOT_END} 100%"    \
        'done'
    assert $? "can't create rootfs partition"

    # Wait for the kernel to pick up the new partition table
    action_run 'Settle partition table'                              \
        "as_root partprobe '$disk' && as_root udevadm settle"        \
        'done'
    assert $? 'partition table did not settle'
}


encrypt_root() {
    #
    # Initialize LUKS2 on the root partition and open it as cryptroot.
    # Passphrase is collected up-front via action_set_password and fed to
    # cryptsetup over stdin in batch mode, so the commands run unattended
    # and can sit inside the standard action UI.
    #
    local part="$1"

    printf_section "Encrypting root partition\n"

    # Retry until success: aborting here would leave the disk partitioned
    # but unencrypted, breaking the rest of the install flow.
    local passphrase
    while :; do
        passphrase=$(action_set_password 'LUKS passphrase') && break
    done

    action_run "Run $(gum style --foreground "$GUM_YELLOW" 'cryptsetup luksFormat') on $(gum style --foreground "$GUM_YELLOW" "$part")"  \
        "printf '%s' '$passphrase' | as_root cryptsetup luksFormat --type luks2 --batch-mode --key-file=- '$part'"                       \
        'done'
    assert $? 'luksFormat failed'

    action_run "Open $(gum style --foreground "$GUM_YELLOW" "$part") as $(gum style --foreground "$GUM_YELLOW" "$CRYPT_NAME")"  \
        "printf '%s' '$passphrase' | as_root cryptsetup open --batch-mode --key-file=- '$part' '$CRYPT_NAME'"                   \
        'done'
    assert $? "can't open $part"
}


format_partitions() {
    #
    # Format ESP (FAT32), boot (btrfs) and root (btrfs over LUKS).
    #
    local esp_part="$1"
    local boot_part="$2"

    printf_section "Formatting filesystems\n"

    action_run "Format ESP -> $(gum style --foreground "$GUM_YELLOW" 'fat32')" \
        "as_root mkfs.fat -F32 '$esp_part'"                                    \
        'done'
    assert $? "can't format ESP partition"

    action_run "Format boot -> $(gum style --foreground "$GUM_YELLOW" 'btrfs')" \
        "as_root mkfs.btrfs -f -L boot '$boot_part'"                            \
        'done'
    assert $? "can't format boot partition"

    action_run "Format rootfs -> $(gum style --foreground "$GUM_YELLOW" 'btrfs')" \
        "as_root mkfs.btrfs -f -L rootfs '/dev/mapper/${CRYPT_NAME}'"             \
        'done'
    assert $? "can't format rootfs partition"
}


create_subvolumes() {
    #
    # Create btrfs subvolumes on boot and root partitions.
    #
    local boot_part="$1"

    printf_section "Creating subvolumes\n"

    # Boot subvolumes ---------------------------------------------------------
    action_run 'Mount top-level of boot partition'   \
        "as_root mount '$boot_part' '$MNT'"          \
        'done'
    assert $? "can't mount $boot_part"

    action_run 'Create @boot, @boot-snapshots'                   \
        "as_root btrfs subvolume create '$MNT/@boot' &&          \
         as_root btrfs subvolume create '$MNT/@boot-snapshots'"  \
        'done'
    assert $? "can't create boot subvolumes"

    action_run 'Unmount boot top-level'              \
        "as_root umount '$MNT'"                      \
        'done'
    assert $? "can't unmount $MNT"

    # Root subvolumes ---------------------------------------------------------
    action_run 'Mount top-level of root partition'                \
        "as_root mount '/dev/mapper/${CRYPT_NAME}' '$MNT'"        \
        'done'
    assert $? "can't mount cryptroot"

    action_run 'Create @, @home, @log, @cache, @snapshots'         \
        "as_root btrfs subvolume create '$MNT/@' &&                \
         as_root btrfs subvolume create '$MNT/@home' &&            \
         as_root btrfs subvolume create '$MNT/@log' &&             \
         as_root btrfs subvolume create '$MNT/@cache' &&           \
         as_root btrfs subvolume create '$MNT/@snapshots'"         \
        'done'
    assert $? "can't create root subvolumes"

    action_run 'Unmount root top-level'              \
        "as_root umount '$MNT'"                      \
        'done'
    assert $? "can't unmount $MNT"
}


mount_targets() {
    #
    # Mount all subvolumes and the ESP at the proper paths under /mnt,
    # creating mount-point directories as needed.
    #
    local esp_part="$1"
    local boot_part="$2"
    local cryptdev="/dev/mapper/${CRYPT_NAME}"

    printf_section "Mounting subvolumes\n"

    # Root @
    action_run "Mount @ at $MNT"                                            \
        "as_root mount -o subvol=@,${BTRFS_OPTS_ROOT} '$cryptdev' '$MNT'"   \
        'done'
    assert $? "can't mount @"

    # Mount-point directories for the rest
    action_run 'Create /home /var/log /var/cache /.snapshots /boot /efi'    \
        "as_root mkdir -p '$MNT/home' '$MNT/var/log' '$MNT/var/cache'       \
                          '$MNT/.snapshots' '$MNT/boot' '$MNT/efi'"         \
        'done'
    assert $? "can't create mount-point directories"

    # Remaining root subvolumes
    action_run "Mount @home at $MNT/home"                                                       \
        "as_root mount -o subvol=@home,${BTRFS_OPTS_OTHER} '$cryptdev' '$MNT/home'"             \
        'done'
    assert $? "can't mount @home"

    action_run "Mount @log at $MNT/var/log"                                                     \
        "as_root mount -o subvol=@log,${BTRFS_OPTS_OTHER} '$cryptdev' '$MNT/var/log'"           \
        'done'
    assert $? "can't mount @log"

    action_run "Mount @cache at $MNT/var/cache"                                                 \
        "as_root mount -o subvol=@cache,${BTRFS_OPTS_OTHER} '$cryptdev' '$MNT/var/cache'"       \
        'done'
    assert $? "can't mount @cache"

    action_run "Mount @snapshots at $MNT/.snapshots"                                            \
        "as_root mount -o subvol=@snapshots,${BTRFS_OPTS_OTHER} '$cryptdev' '$MNT/.snapshots'"  \
        'done'
    assert $? "can't mount @snapshots"

    # Boot subvolumes
    action_run "Mount @boot at $MNT/boot"                                                  \
        "as_root mount -o subvol=@boot,${BTRFS_OPTS_ROOT} '$boot_part' '$MNT/boot'"        \
        'done'
    assert $? "can't mount @boot"

    action_run "Create $MNT/boot/.snapshots"            \
        "as_root mkdir -p '$MNT/boot/.snapshots'"       \
        'done'
    assert $? "can't create $MNT/boot/.snapshots"

    action_run "Mount @boot-snapshots at $MNT/boot/.snapshots"                                            \
        "as_root mount -o subvol=@boot-snapshots,${BTRFS_OPTS_ROOT} '$boot_part' '$MNT/boot/.snapshots'"  \
        'done'
    assert $? "can't mount @boot-snapshots"

    # ESP
    action_run "Mount ESP at $MNT/efi"            \
        "as_root mount '$esp_part' '$MNT/efi'"    \
        'done'
    assert $? "can't mount ESP"
}


generate_fstab() {
    #
    # Run genfstab and tighten /efi mount options.
    # genfstab handles /boot and /boot/.snapshots correctly already.
    #
    printf_section "Generating fstab\n"

    action_run "Create $MNT/etc"                  \
        "as_root mkdir -p '$MNT/etc'"             \
        'done'
    assert $? "can't create $MNT/etc"

    action_run 'Run genfstab -U /mnt >> /mnt/etc/fstab'         \
        "as_root bash -c 'genfstab -U $MNT >> $MNT/etc/fstab'"  \
        'done'
    assert $? 'genfstab failed'

    # Tighten /efi: replace the auto-generated options token with EFI_OPTS.
    # Match: <device><spaces>/efi<spaces>vfat<spaces><opts-token>
    local cmd_fix_efi
    cmd_fix_efi="as_root sed -i -E 's|(^[^[:space:]#]+[[:space:]]+/efi[[:space:]]+vfat[[:space:]]+)[^[:space:]]+|\\1${EFI_OPTS}|' '$MNT/etc/fstab'"
    action_run 'Tighten /efi mount options' "$cmd_fix_efi" 'done'
    assert $? "can't tighten /efi options"
}


main() {

    ## Refuse to run as non-root
    # Partitioning, mkfs, mount, cryptsetup all require root.
    if [ "$EUID" -ne 0 ]; then
        printf_error "%b\n" 'this script must be run as root'
        exit 1
    fi

    ## Get gum

    request_gum
    assert $? 'no gum - no fun :('

    ## Init

    printf_section "Starting\n"
    printf_action "Common lib version: ${STYLE_CLR}${COMMON_VERSION}\n"
    start_logger
    printf_action "Log started: ${STYLE_CLR}${LOG_FILE}\n"

    ## Required tools

    require_tools

    ## Select disk

    printf_section "Select target disk\n"
    local disk
    disk=$(select_disk)
    if [ -z "$disk" ]; then
        echo
        printf_warning 'no disk selected\n'
        return 0
    fi
    printf_action "Selected disk: ${STYLE_CLR}%b\n" \
        "$(gum style --foreground "$GUM_YELLOW" "$disk")"

    ## Verify disk is empty

    printf_section "Checking disk\n"
    if ! is_disk_empty "$disk"; then
        printf_warning "disk %b is not empty\n\n"  \
            "$(gum style --foreground "$GUM_YELLOW" "$disk")"
        echo 'Existing layout:'
        as_root lsblk "$disk"
        echo
        printf_error "%b\n" 'wipe the disk first (e.g. wipefs -a / sgdisk --zap-all) and re-run'
        exit 1
    fi
    printf_action 'Disk is empty\n'

    ## Confirm destructive operation

    echo
    printf_warning 'About to partition %b: ALL DATA WILL BE LOST.\n' \
        "$(gum style --foreground "$GUM_YELLOW" "$disk")"
    printf_action 'Proceed? '
    if ! ask_yn; then
        echo
        return 0
    fi

    ## Build partition paths

    local esp_part boot_part root_part
    esp_part=$(partition_path "$disk" 1)
    boot_part=$(partition_path "$disk" 2)
    root_part=$(partition_path "$disk" 3)

    ## Partition / encrypt / format / subvolumes / mount

    echo
    echo "$esp_part"
    echo "$boot_part"
    echo "$root_part"

    # partition_disk     "$disk"
    # encrypt_root       "$root_part"
    # format_partitions  "$esp_part" "$boot_part"
    # create_subvolumes  "$boot_part"
    # mount_targets      "$esp_part" "$boot_part"

    ## genfstab (optional)

    # printf_section "Generate fstab?\n"
    # printf_action "Run %b now? " \
    #     "$(gum style --foreground "$GUM_YELLOW" 'genfstab -U /mnt >> /mnt/etc/fstab')"
    # if ask_yn; then
    #     generate_fstab
    # else
    #     printf_action 'Skipped\n'
    # fi

    echo
    return 0
}


main "$@"
